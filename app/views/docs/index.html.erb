<main>
  <header>
    <p>Documentation</p>
    <h1>Shared Doc Standard</h1>
    <p>
      A portable documentation format that keeps content consistent across the Rails apps.
    </p>
    <div>
      <span>Source: <span>docs/docs.json</span></span>
      <span>Entries: <%= @docs.count %></span>
    </div>
    <%= form_with url: docs_path, method: :get, local: true do |form| %>
      <div>
        <%= form.label :q, "Search docs" %>
        <%= form.search_field :q, value: @query, placeholder: "Search docs" %>
        <%= form.submit "Search" %>
        <% if @query.present? %>
          <%= link_to "Clear", docs_path %>
        <% end %>
      </div>
      <% if @query.present? %>
        <p><%= pluralize(@docs.count, "result") %> for "<%= h(@query) %>"</p>
      <% end %>
    <% end %>
  </header>

  <% @categories.each do |category, docs| %>
    <section>
      <div>
        <h2><%= h(category) %></h2>
        <span><%= docs.count %> docs</span>
      </div>
      <div>
        <% docs.each do |doc| %>
          <article>
            <div>
              <p><%= h(doc.status.capitalize) %> · <%= h(doc.audience.join(", ")) %></p>
              <h3><%= link_to h(doc.title), doc_path(doc.id) %></h3>
              <p><%= h(doc.summary) %></p>
            </div>
            <div>
              <div>
                <% doc.tags.each do |tag| %>
                  <span><%= h(tag) %></span>
                <% end %>
              </div>
              <p>Updated <%= h(doc.updated_at) %></p>
            </div>
          </article>
        <% end %>
      </div>
    </section>
  <% end %>
</main>
